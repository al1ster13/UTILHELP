@echo off
chcp 65001 >nul
title Компиляция Qt ресурсов

echo.
echo ============================================================
echo КОМПИЛЯЦИЯ QT РЕСУРСОВ
echo ============================================================
echo.

cd /d "%~dp0\.."

python compile_resources.py

if %ERRORLEVEL% EQU 0 (
    echo.
    echo ============================================================
    echo ✓ РЕСУРСЫ СКОМПИЛИРОВАНЫ УСПЕШНО
    echo ============================================================
    echo.
    echo Создан файл: resources_rc.py
    echo.
    echo Следующий шаг: 1_build_project.bat
    echo.
) else (
    echo.
    echo ============================================================
    echo ✗ КОМПИЛЯЦИЯ НЕ УДАЛАСЬ
    echo ============================================================
    echo.
)

pause
