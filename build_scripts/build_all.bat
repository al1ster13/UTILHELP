@echo off
chcp 65001 >nul
title Полная сборка UTILHELP

echo.
echo ============================================================
echo ПОЛНАЯ СБОРКА UTILHELP
echo ============================================================
echo.

cd /d "%~dp0\.."

echo Шаг 1/2: Сборка проекта...
echo.
python build_scripts\1_build_project.py

if %ERRORLEVEL% NEQ 0 (
    echo.
    echo ============================================================
    echo ✗ СБОРКА ПРОЕКТА НЕ УДАЛАСЬ
    echo ============================================================
    echo.
    pause
    exit /b 1
)

echo.
echo ============================================================
echo ✓ Проект собран успешно
echo ============================================================
echo.
echo Шаг 2/2: Создание установщика...
echo.

python build_scripts\2_create_installer.py

if %ERRORLEVEL% NEQ 0 (
    echo.
    echo ============================================================
    echo ✗ СОЗДАНИЕ УСТАНОВЩИКА НЕ УДАЛОСЬ
    echo ============================================================
    echo.
    pause
    exit /b 1
)

echo.
echo ============================================================
echo ✓ ПОЛНАЯ СБОРКА ЗАВЕРШЕНА УСПЕШНО
echo ============================================================
echo.
echo Результат: installer_output\UTILHELP_Setup_v1.1.exe
echo.

pause
